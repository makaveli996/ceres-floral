# Ceres Floral — PrestaShop 8.2.3 (Docker). Copy to .env or run `make env`.
#
# Pierwsze uruchomienie (gdy w ./prestashop są tylko themes/modules/override z gita):
#   make init-fresh
# Potem: make perms && make perms-cache && npm install && make theme-build
# Na Windows: make host (wpis w hosts dla DOMAIN) — opcjonalnie przed init-fresh.
#
# Rdzeń Presta nie jest w repozytorium — `make copy-core` (w init-fresh) kopiuje pliki z obrazu Docker.
# W repozytorium nie ma modułów ani override z innego sklepu — tylko puste `prestashop/modules/` (ew. własne moduły dodasz sam).
#
WEB_PORT=8090
PMA_PORT=8091
DOMAIN=ceres-floral.test

DB_NAME=prestashop
DB_USER=prestashop
DB_PASS=prestashop
DB_ROOT_PASS=root
